# 제품 식별 우선순위: ① 로컬 claude CLI(Max 구독, 무과금) → ② API 키 → ③ 휴리스틱
# 보통 .env 없이도 됩니다 — claude CLI가 깔려 있으면 그걸로 식별합니다.

# (선택) CLI 식별에 쓸 모델 — 기본 haiku (Max 사용량 절약). sonnet/opus 도 가능.
EXTRACT_CLI_MODEL=haiku

# (선택) CLI 대신 API로 식별하려면 키 입력 (별도 종량 과금됨)
ANTHROPIC_API_KEY=
EXTRACT_MODEL=claude-haiku-4-5-20251001

# 아마존 어소시에이트 태그 — 어필리에이트 링크에 부착(수익화). 예: mytag-20
AMAZON_ASSOC_TAG=
# 아마존 도메인 (기본 미국)
AMAZON_DOMAIN=www.amazon.com
